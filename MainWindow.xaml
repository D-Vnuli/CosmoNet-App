<Window x:Class="CosmoNet.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CosmoNet" Height="640" Width="980" MinHeight="560" MinWidth="820"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,22">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="CosmoNet" FontSize="30" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                <TextBlock Text="Windows-клиент для вашей подписки VPN" FontSize="14" Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
            <Border DockPanel.Dock="Right" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Background="White" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="{Binding CoreStatus}" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="{Binding AdminStatus}" Margin="0,3,0,0" Foreground="{StaticResource MutedBrush}" />
                </StackPanel>
            </Border>
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="430" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" MinWidth="280" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Подписка" FontSize="18" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                    <TextBox Grid.Row="1" Margin="0,14,0,12" Text="{Binding SubscriptionUrl, UpdateSourceTrigger=PropertyChanged}" ToolTip="Ссылка вида https://ваш-домен/sub/идентификатор" />
                    <WrapPanel Grid.Row="2" Margin="0,0,0,18">
                        <Button Content="Обновить" Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
                        <Button Content="Сохранить" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                        <Button Content="Папка данных" Command="{Binding OpenDataFolderCommand}" />
                    </WrapPanel>
                    <ListBox Grid.Row="3" ItemsSource="{Binding Profiles}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                        <TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0">
                                            <Run Text="{Binding Network}" /><Run Text=" / " /><Run Text="{Binding Security}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Protocol}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Padding="22">
                <StackPanel>
                    <TextBlock Text="Подключение" FontSize="18" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                    <Border Margin="0,18,0,18" Padding="18" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                            <TextBlock Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}">
                                <Run Text="Последнее обновление: " /><Run Text="{Binding LastRefresh}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <CheckBox Content="TUN-режим для всего трафика" IsChecked="{Binding UseTunMode}" Margin="0,0,0,10" />
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,22" Text="Если TUN выключен, приложение поднимет локальный mixed proxy на 127.0.0.1:20808." />
                    <Button Content="Подключить" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" />
                    <Button Content="Отключить" Command="{Binding DisconnectCommand}" />
                </StackPanel>
            </Border>
        </Grid>
        <TextBlock Grid.Row="2" Margin="0,18,0,0" Foreground="{StaticResource MutedBrush}" Text="MVP: подписка -> sing-box config -> запуск локального ядра. Следующий слой: установщик, tray, автообновление ядра и системный proxy fallback." />
    </Grid>
</Window>
