<Window x:Class="CosmoNet.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CosmoNet" Height="760" Width="560" MinHeight="700" MinWidth="520" Background="#051024">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#261F4E78" />
            <Setter Property="BorderBrush" Value="#3F8AB5E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PowerButton" TargetType="Button">
            <Setter Property="Width" Value="154" />
            <Setter Property="Height" Value="154" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="54" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Margin="-10" Stroke="#884EACFF" StrokeThickness="2">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#3080D8FF" Opacity="0.8" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Border Background="{TemplateBinding Background}" CornerRadius="77" BorderBrush="#A663B8FF" BorderThickness="1.5">
                                <Grid>
                                    <Ellipse Margin="9">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush GradientOrigin="0.32,0.22" Center="0.5,0.5" RadiusX="0.72" RadiusY="0.72">
                                                <GradientStop Color="#45FFFFFF" Offset="0" />
                                                <GradientStop Color="#18FFFFFF" Offset="0.48" />
                                                <GradientStop Color="#00000000" Offset="1" />
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Ellipse Margin="18" Stroke="#45D9EDFF" StrokeThickness="1" />
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubscriptionExpander" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="0">
                                <ContentPresenter ContentSource="Header" />
                            </ToggleButton>
                            <ContentPresenter x:Name="Details" ContentSource="Content" Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Details" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#DCEAFF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Surface" Background="Transparent" CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#2E5F9FE0" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Image Source="pack://siteoforigin:,,,/Resources/cosmic-background.png" Stretch="UniformToFill" />
        <Rectangle Fill="#42020B1D" IsHitTestVisible="False" />

        <Grid Margin="22,18,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>
                <Button Style="{StaticResource IconButton}" Command="{Binding ToggleMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Меню" AutomationProperties.Name="Главное меню">
                    <StackPanel Width="18">
                        <Rectangle Height="2" RadiusX="1" RadiusY="1" Fill="White" Margin="0,0,0,4" />
                        <Rectangle Height="2" RadiusX="1" RadiusY="1" Fill="White" Margin="0,0,0,4" />
                        <Rectangle Height="2" RadiusX="1" RadiusY="1" Fill="White" />
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" Text="CosmoNet" Foreground="White" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />

                <ToggleButton x:Name="TelegramToggle" Grid.Column="2" Width="42" Height="42" Padding="0" Background="#261F4E78" BorderBrush="#3F8AB5E3" BorderThickness="1" ToolTip="Telegram">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid>
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                                    <Grid>
                                        <Path x:Name="TelegramIcon" Width="19" Height="19" Stretch="Uniform" Fill="White" Data="M1,8.6 L20,1.2 C20.8,0.9 21.5,1.6 21.2,2.4 L15.3,20.2 C15,21.1 13.8,21.3 13.2,20.6 L9.4,16.3 L7.1,18.5 C6.4,19.1 5.3,18.7 5.2,17.8 L4.8,13.4 L1.4,11.3 C0.5,10.8 0.3,9.1 1,8.6 Z M6.6,12.4 L7.1,16.6 L9.3,14.5 L15.9,6.4 Z" />
                                        <Border x:Name="Avatar" Width="28" Height="28" CornerRadius="14" Background="#386CA6FF" Visibility="Collapsed">
                                            <TextBlock Text="{Binding AccountDisplayText}" FontSize="10" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis" TextAlignment="Center" VerticalAlignment="Center" Margin="3,0" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Ellipse x:Name="OnlineDot" Width="9" Height="9" Fill="#35D587" Stroke="#07142B" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2" Visibility="Collapsed" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding AccountSession.IsAuthorized}" Value="True">
                                    <Setter TargetName="TelegramIcon" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="Avatar" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="OnlineDot" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <Popup PlacementTarget="{Binding ElementName=TelegramToggle}" Placement="Bottom" StaysOpen="False" IsOpen="{Binding IsChecked, ElementName=TelegramToggle}" AllowsTransparency="True">
                    <Border Width="272" Margin="0,10,0,0" Background="#F9112340" BorderBrush="#428AB5E3" BorderThickness="1" CornerRadius="14" Padding="16">
                        <StackPanel>
                            <TextBlock Text="{Binding AccountDisplayText}" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="{Binding AuthStatus}" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#B9CCE5" FontSize="12" />
                            <TextBlock Text="{Binding LoginCode}" FontSize="24" FontWeight="SemiBold" Foreground="White" Margin="0,12,0,0" HorizontalAlignment="Center" />
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Получить код" Command="{Binding GenerateLoginCodeCommand}" Padding="8,6" FontSize="12" />
                                <Button Grid.Column="2" Content="Проверить" Command="{Binding CheckAuthStatusCommand}" Padding="8,6" FontSize="12" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <TabControl x:Name="MainViews" Grid.Row="1" Margin="0,12,0,0" Background="Transparent" BorderThickness="0">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl"><ContentPresenter Content="{TemplateBinding SelectedContent}" /></ControlTemplate>
                </TabControl.Template>
                <TabItem x:Name="HomeTab" IsSelected="True">
                    <Grid>
                        <StackPanel Width="348" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Style="{StaticResource PowerButton}" Command="{Binding PowerCommand}" Background="{Binding PowerButtonColor}" ToolTip="Подключить или отключить VPN" Content="⏻" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ConnectionStateText}" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,24,0,0" />
                            <TextBlock Text="{Binding StatusText}" Foreground="#ACC2DD" FontSize="12" HorizontalAlignment="Center" Margin="0,7,0,0" />

                            <Grid Width="260" HorizontalAlignment="Center" Margin="0,26,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="16" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="28" /><RowDefinition Height="28" /><RowDefinition Height="28" /></Grid.RowDefinitions>
                                <Ellipse Width="9" Height="9" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#35D587" />
                                            <Style.Triggers><DataTrigger Binding="{Binding Profiles.Count}" Value="0"><Setter Property="Fill" Value="#E6585C" /></DataTrigger></Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Grid.Column="2" FontSize="12" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Сервер доступен" />
                                            <Setter Property="Foreground" Value="#DCEAFF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Profiles.Count}" Value="0">
                                                    <Setter Property="Text" Value="Ожидает подписку" />
                                                    <Setter Property="Foreground" Value="#F08A8E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Grid Grid.Row="1" Width="16" Height="16" VerticalAlignment="Center">
                                    <Ellipse Stroke="#8DBBEE" StrokeThickness="1.2" />
                                    <Path Stroke="#8DBBEE" StrokeThickness="1" Data="M1,8 L15,8 M8,1 C5,4 5,12 8,15 M8,1 C11,4 11,12 8,15" />
                                </Grid>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding CurrentServerText}" Foreground="#E8F1FF" FontSize="12" VerticalAlignment="Center" />
                                <Path Grid.Row="2" Width="16" Height="16" Stretch="Uniform" Fill="#8DBBEE" VerticalAlignment="Center" Data="M8,1 L14,4 L14,8 C14,11.5 11.7,14.4 8,15.8 C4.3,14.4 2,11.5 2,8 L2,4 Z M5.5,8 L7.2,9.7 L10.8,6.1" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding TrafficModeText}" Foreground="#B9CCE5" FontSize="12" VerticalAlignment="Center" />
                            </Grid>

                            <Expander Style="{StaticResource SubscriptionExpander}" IsExpanded="False" HorizontalAlignment="Center" Margin="0,28,0,0">
                                <Expander.Header>
                                    <Border Width="348" Background="#4A173866" CornerRadius="14" Padding="15,13" BorderBrush="#3474A5D8" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <Border Width="36" Height="36" Background="#345B9CFF" CornerRadius="18" VerticalAlignment="Center">
                                                <Path Width="18" Height="18" Stretch="Uniform" Fill="#B8DAFF" Data="M4,2 L4,5 M12,2 L12,5 M3,4 L13,4 L13,15 L3,15 Z M5,8 L7,8 M9,8 L11,8 M5,11 L7,11 M9,11 L11,11" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="11,0,0,0"><TextBlock Text="Подписка" FontWeight="SemiBold" Foreground="White" /><TextBlock Text="Действует до" Foreground="#9FB9D7" FontSize="11" Margin="0,2,0,0" /><TextBlock Text="{Binding SubscriptionExpiresText}" Foreground="#77B7FF" FontWeight="SemiBold" FontSize="14" /></StackPanel>
                                            <TextBlock Grid.Column="2" Text="›" Foreground="White" FontSize="30" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </Expander.Header>
                                <Border Width="348" Background="#E9122B50" BorderBrush="#3474A5D8" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,8,0,0">
                                    <StackPanel><TextBlock Text="{Binding SubscriptionStatusText}" Foreground="White" FontWeight="SemiBold" /><TextBlock Text="{Binding SubscriptionTariffText}" Foreground="#B9CCE5" Margin="0,8,0,0" /><TextBlock Text="{Binding SubscriptionDevicesText}" Foreground="#B9CCE5" Margin="0,4,0,0" /><TextBlock Text="{Binding SubscriptionTrafficText}" Foreground="#B9CCE5" Margin="0,4,0,0" /><Button Content="Обновить" Command="{Binding RefreshCommand}" HorizontalAlignment="Left" Margin="0,12,0,0" /></StackPanel>
                                </Border>
                            </Expander>
                            <TextBlock Text="CosmoNet • Windows VPN-клиент" Foreground="#7895B5" FontSize="10" HorizontalAlignment="Center" Margin="0,14,0,0" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem x:Name="ApplicationsTab">
                    <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="170" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#CE102442" CornerRadius="14" Padding="16"><StackPanel><TextBlock Text="Режим трафика" Foreground="White" FontSize="16" FontWeight="SemiBold" /><RadioButton Content="Весь трафик через VPN" IsChecked="{Binding IsAllTrafficMode}" Foreground="#DCEAFF" Margin="0,16,0,8" /><RadioButton Content="Только выбранные" IsChecked="{Binding IsSelectedAppsMode}" Foreground="#DCEAFF" /><Button Content="Сохранить" Command="{Binding SaveCommand}" HorizontalAlignment="Left" Margin="0,16,0,0" /></StackPanel></Border>
                        <Border Grid.Column="2" Background="#CE102442" CornerRadius="14" Padding="16"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><DockPanel Margin="0,0,0,12"><Button Content="Обновить" Command="{Binding LoadApplicationsCommand}" DockPanel.Dock="Right" /><TextBlock Text="Приложения для VPN" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" /></DockPanel><DockPanel Grid.Row="1" Margin="0,0,0,12"><Button Content="Добавить" Command="{Binding AddManualApplicationCommand}" DockPanel.Dock="Right" Margin="8,0,0,0" /><TextBox Text="{Binding ManualProcessName, UpdateSourceTrigger=PropertyChanged}" /></DockPanel><ListBox Grid.Row="2" ItemsSource="{Binding AvailableApplications}" Background="#5A07152C" BorderThickness="0" Foreground="White"><ListBox.ItemTemplate><DataTemplate><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="8,6" Foreground="White"><StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" /><TextBlock Text="{Binding RouteLabel}" Foreground="#A8BFDA" FontSize="11" /></StackPanel></CheckBox></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></Border>
                    </Grid>
                </TabItem>
                <TabItem x:Name="InstructionsTab"><Border Margin="0,10,0,0" Background="#CE102442" CornerRadius="14" Padding="20"><StackPanel><TextBlock Text="Быстрый старт" Foreground="White" FontSize="19" FontWeight="SemiBold" /><TextBlock Text="1. Получите код Telegram-авторизации и подтвердите вход в боте." Foreground="#DCEAFF" Margin="0,18,0,0" TextWrapping="Wrap" /><TextBlock Text="2. Обновите подписку, чтобы приложение увидело профили CosmoNet." Foreground="#DCEAFF" Margin="0,10,0,0" TextWrapping="Wrap" /><TextBlock Text="3. Выберите режим трафика и нажмите кнопку питания для подключения." Foreground="#DCEAFF" Margin="0,10,0,0" TextWrapping="Wrap" /></StackPanel></Border></TabItem>
            </TabControl>
        </Grid>

        <Border Grid.ZIndex="10" Margin="0,66,0,0" Background="#01000000" Visibility="{Binding IsMenuOpen, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}" MouseLeftButtonDown="OnMenuBackdropMouseDown" />
        <Border Grid.ZIndex="11" Width="244" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="12,66,0,12" Padding="16" Background="#F30B1A33" BorderBrush="#4874A5D8" BorderThickness="1" CornerRadius="16" Visibility="{Binding IsMenuOpen, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.35" Color="#000000" /></Border.Effect>
            <StackPanel><TextBlock Text="CosmoNet" Foreground="White" FontSize="19" FontWeight="SemiBold" Margin="4,6,0,20" /><ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource MenuItem}" SelectedIndex="{Binding SelectedIndex, ElementName=MainViews, Mode=TwoWay}" SelectionChanged="OnMenuSelectionChanged" PreviewMouseLeftButtonUp="OnMenuNavigationMouseUp"><ListBoxItem Content="Главная" /><ListBoxItem Content="Приложения" /><ListBoxItem Content="Инструкции" /></ListBox></StackPanel>
        </Border>
    </Grid>
</Window>
