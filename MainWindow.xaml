<Window x:Class="CosmoNet.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CosmoNet" Height="760" Width="560" MinHeight="760" MinWidth="560" MaxHeight="760" MaxWidth="560" ResizeMode="NoResize" WindowStyle="None" Background="#051024" Opacity="0" PreviewKeyDown="OnWindowPreviewKeyDown" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="AuthButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2D5D9AFF" />
            <Setter Property="BorderBrush" Value="#7EB8FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" /></Border></ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="AuthMethodButton" TargetType="Button">
            <Setter Property="Background" Value="#221C416D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#467EB8ED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}"><ContentPresenter /></Border></ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#261F4E78" />
            <Setter Property="BorderBrush" Value="#3F8AB5E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#DCEAFF" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A305C87" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PowerButton" TargetType="Button">
            <Setter Property="Width" Value="154" />
            <Setter Property="Height" Value="154" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="54" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Margin="-10" Stroke="#884EACFF" StrokeThickness="2">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#3080D8FF" Opacity="0.8" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Border Background="{TemplateBinding Background}" CornerRadius="77" BorderBrush="#A663B8FF" BorderThickness="1.5">
                                <Grid>
                                    <Ellipse Margin="9">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush GradientOrigin="0.32,0.22" Center="0.5,0.5" RadiusX="0.72" RadiusY="0.72">
                                                <GradientStop Color="#45FFFFFF" Offset="0" />
                                                <GradientStop Color="#18FFFFFF" Offset="0.48" />
                                                <GradientStop Color="#00000000" Offset="1" />
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Ellipse Margin="18" Stroke="#45D9EDFF" StrokeThickness="1" />
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubscriptionExpander" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton HorizontalContentAlignment="Stretch" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="0">
                                <ContentPresenter ContentSource="Header" />
                            </ToggleButton>
                            <ContentPresenter x:Name="Details" ContentSource="Content" Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Details" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#DCEAFF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Surface" Background="Transparent" CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#2E5F9FE0" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Image Source="pack://siteoforigin:,,,/Resources/cosmic-background.png" Stretch="UniformToFill" />
        <Rectangle Fill="#42020B1D" IsHitTestVisible="False" />

        <Grid Margin="22,48,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Style="{StaticResource IconButton}" Command="{Binding ToggleMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Меню" AutomationProperties.Name="Главное меню">
                    <StackPanel Width="18">
                        <Rectangle Height="2" RadiusX="1" RadiusY="1" Fill="White" Margin="0,0,0,4" />
                        <Rectangle Height="2" RadiusX="1" RadiusY="1" Fill="White" Margin="0,0,0,4" />
                        <Rectangle Height="2" RadiusX="1" RadiusY="1" Fill="White" />
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid>
                        <Button x:Name="AuthButton" Content="{Binding AccountButtonText}" Command="{Binding ShowAuthMethodsCommand}"
                                Style="{StaticResource AuthButton}" MinWidth="112" ToolTip="&#x412;&#x43E;&#x439;&#x442;&#x438; &#x432; CosmoNet" />
                        <Popup PlacementTarget="{Binding ElementName=AuthButton}" Placement="Bottom" StaysOpen="False"
                               IsOpen="{Binding IsAuthMenuOpen}" AllowsTransparency="True">
                            <Border Width="164" Margin="0,10,0,0" Padding="10" Background="#F9122746" BorderBrush="#6E8CC7FF" BorderThickness="1" CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="&#x412;&#x43E;&#x439;&#x442;&#x438; &#x441; &#x43F;&#x43E;&#x43C;&#x43E;&#x449;&#x44C;&#x44E;" Foreground="#BFD9F7" FontSize="12" Margin="2,0,0,9" />
                                    <Button Command="{Binding LoginCommand}" Style="{StaticResource AuthMethodButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="30" Height="30" CornerRadius="15" Background="#2A8FD5" Margin="0,0,10,0">
                                                <Path Width="17" Height="17" Stretch="Uniform" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M1,8.6 L20,1.2 C20.8,0.9 21.5,1.6 21.2,2.4 L15.3,20.2 C15,21.1 13.8,21.3 13.2,20.6 L9.4,16.3 L7.1,18.5 C6.4,19.1 5.3,18.7 5.2,17.8 L4.8,13.4 L1.4,11.3 C0.5,10.8 0.3,9.1 1,8.6 Z M6.6,12.4 L7.1,16.6 L9.3,14.5 L15.9,6.4 Z" />
                                            </Border>
                                            <TextBlock Text="Telegram" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Button Content="&#x412;&#x44B;&#x439;&#x442;&#x438;" Command="{Binding LogoutCommand}" Margin="8,0,0,0" Padding="10,6"
                            Visibility="{Binding IsAuthorized, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
</Grid>

            <TabControl x:Name="MainViews" Grid.Row="1" Margin="0,12,0,0" Background="Transparent" BorderThickness="0">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl"><ContentPresenter Content="{TemplateBinding SelectedContent}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" /></ControlTemplate>
                </TabControl.Template>
                <TabItem x:Name="HomeTab" IsSelected="True" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Width="348" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Style="{StaticResource PowerButton}" Command="{Binding PowerCommand}" Background="{Binding PowerButtonColor}" ToolTip="Подключить или отключить VPN" Content="⏻" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding ConnectionStateText}" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,24,0,0" />

                            <!-- The information rows are measured by their real content width.
                                 This centers the visible block itself, not an oversized invisible container. -->
                            <!-- Optical centering: the icon column makes the block look slightly left-heavy,
                                 so the complete three-row block is shifted 16 DIPs to the right. -->
                            <Grid HorizontalAlignment="Center" Margin="0,28,0,0">
                                <Grid.RenderTransform>
                                    <TranslateTransform X="16" />
                                </Grid.RenderTransform>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="28" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Row="0" Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center">
                                    <Ellipse Width="9" Height="9" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding ServerStatusColor}" />
                                </Grid>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ServerStatusText}" Foreground="{Binding ServerStatusColor}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />

                                <ContentControl Grid.Row="1" Grid.Column="0" Width="20" Height="14" Content="{Binding CurrentCountryCode}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ContentControl">
                                                        <TextBlock Text="🌐" Foreground="#E8F1FF" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentCountryCode}" Value="NL">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ContentControl">
                                                                <Border BorderBrush="#6687A8C8" BorderThickness="0.5" CornerRadius="1" ClipToBounds="True">
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition />
                                                                            <RowDefinition />
                                                                            <RowDefinition />
                                                                        </Grid.RowDefinitions>
                                                                        <Rectangle Grid.Row="0" Fill="#AE1C28" />
                                                                        <Rectangle Grid.Row="1" Fill="White" />
                                                                        <Rectangle Grid.Row="2" Fill="#21468B" />
                                                                    </Grid>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding CurrentCountryName}" Foreground="#E8F1FF" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />

                                <Grid Grid.Row="2" Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center">
                                    <Path Width="16" Height="16" Stretch="Uniform" Fill="#8DBBEE" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M8,1 L14,4 L14,8 C14,11.5 11.7,14.4 8,15.8 C4.3,14.4 2,11.5 2,8 L2,4 Z M5.5,8 L7.2,9.7 L10.8,6.1" />
                                </Grid>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding TrafficModeText}" Foreground="#B9CCE5" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            </Grid>
                            <!-- The tab content area is a few pixels narrower because of the right-side scroll area.
                                 Shift the complete subscription card slightly right so its visible center matches
                                 the power button and the true center line of the application window. -->
                            <Button Width="236" HorizontalAlignment="Center" Margin="0,22,0,0" Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="OnSubscriptionCardClick" AutomationProperties.Name="Детали подписки">
                                <Border Width="236" Background="#56142F58" CornerRadius="16" Padding="15,13" BorderBrush="#3C74A5D8" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" Background="#2B6AA6E8" CornerRadius="18" VerticalAlignment="Center">
                                            <TextBlock Text="&#x27F3;" Foreground="#D9EDFF" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="11,0,0,0"><TextBlock Text="Подписка" FontWeight="SemiBold" Foreground="White" /><TextBlock Text="Действует до" Foreground="#9FB9D7" FontSize="11" Margin="0,2,0,0" /><TextBlock Text="{Binding SubscriptionExpiresText}" Foreground="#77B7FF" FontWeight="SemiBold" FontSize="14" /></StackPanel>
                                        <TextBlock Grid.Column="2" Text="›" Foreground="White" FontSize="30" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Button>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="CosmoNet • Windows VPN-клиент" Foreground="#7895B5" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="ApplicationsTab">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#CE102442" CornerRadius="14" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.ColumnSpan="2" Text="Режим трафика" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
                                    <RadioButton Content="Весь трафик через VPN" IsChecked="{Binding IsAllTrafficMode}" Foreground="#DCEAFF" Margin="0,0,18,0" />
                                    <RadioButton Content="Только выбранные" IsChecked="{Binding IsSelectedAppsMode}" Foreground="#DCEAFF" />
                                </StackPanel>
                                <Button Grid.Row="1" Grid.Column="1" Content="Сохранить" Command="{Binding SaveCommand}" Margin="12,8,0,0" Padding="12,6" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Background="#CE102442" CornerRadius="14" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="Приложения для VPN" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </DockPanel>
                                <DockPanel Grid.Row="1" Margin="0,0,0,12">
                                    <Button Content="Выбрать .exe" Command="{Binding BrowseApplicationCommand}" DockPanel.Dock="Left" />
                                </DockPanel>
                                <ListBox Grid.Row="2" ItemsSource="{Binding AvailableApplications}" Background="#5A07152C" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,6" HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24" />
                                                        <ColumnDefinition Width="38" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="32" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Foreground="White" />
                                                    <Border Grid.Column="1" Width="28" Height="28" Background="#214267" CornerRadius="6" VerticalAlignment="Center">
                                                        <Grid>
                                                            <TextBlock Text="□" Foreground="#B9D8F5" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            <Image Source="{Binding Icon}" Stretch="Uniform" Margin="2" />
                                                        </Grid>
                                                    </Border>
                                                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                        <TextBlock Grid.Row="1" Text="{Binding RouteLabel}" Foreground="#A8BFDA" FontSize="11" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}" ToolTipService.ShowDuration="60000" />
                                                    </Grid>
                                                    <Button Grid.Column="3" Content="×" Width="24" Height="24" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" ToolTip="Удалить приложение" Click="OnRemoveApplicationClick" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem x:Name="InstructionsTab">
                    <Border Margin="0,10,0,0" Background="#CE102442" CornerRadius="14" Padding="18,18,10,18">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Text="Как пользоваться CosmoNet"
                                           Foreground="White"
                                           FontSize="21"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Ниже собраны все основные действия: от первого запуска до решения проблем с подключением."
                                           Foreground="#AFC7E3"
                                           FontSize="12"
                                           Margin="0,6,0,16"
                                           TextWrapping="Wrap" />

                                <Border Background="#5A0B1E3A" BorderBrush="#3672A4D4" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Быстрый запуск"
                                                   Foreground="#B9D9FF"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />

                                        <TextBlock Foreground="White" Margin="0,13,0,0" TextWrapping="Wrap">
                                            <Run Text="1. Запустите приложение от имени администратора." FontWeight="SemiBold" />
                                        </TextBlock>
                                        <TextBlock Text="Это нужно Windows для создания защищённого VPN-подключения. Без прав администратора кнопка подключения может не сработать."
                                                   Foreground="#C7D8EC" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />

                                        <TextBlock Foreground="White" Margin="0,12,0,0" TextWrapping="Wrap">
                                            <Run Text="2. Добавьте личную подписку." FontWeight="SemiBold" />
                                        </TextBlock>
                                        <TextBlock Text="Нажмите карточку «Подписка» на главном экране. Вставьте полученную от CosmoNet ссылку в нижнее поле и нажмите «Загрузить». Ссылка сохраняется на этом компьютере, поэтому повторно вводить её при каждом запуске не нужно."
                                                   Foreground="#C7D8EC" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />

                                        <TextBlock Foreground="White" Margin="0,12,0,0" TextWrapping="Wrap">
                                            <Run Text="3. Проверьте данные подписки." FontWeight="SemiBold" />
                                        </TextBlock>
                                        <TextBlock Text="На карточке должна появиться дата окончания. Откройте карточку ещё раз и убедитесь, что подписка активна. Данные обновляются автоматически; если информация не появилась сразу, подождите до 30 секунд."
                                                   Foreground="#C7D8EC" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />

                                        <TextBlock Foreground="White" Margin="0,12,0,0" TextWrapping="Wrap">
                                            <Run Text="4. Нажмите большую кнопку питания." FontWeight="SemiBold" />
                                        </TextBlock>
                                        <TextBlock Text="Серая кнопка означает, что VPN выключен. Синяя — идёт подключение. Зелёная — VPN работает. Для отключения нажмите эту же кнопку ещё раз."
                                                   Foreground="#C7D8EC" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#5A0B1E3A" BorderBrush="#3672A4D4" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Что означает информация на главном экране"
                                                   Foreground="#B9D9FF"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="• «Сервер доступен» — приложение видит сервер CosmoNet. Это не означает, что VPN уже включён."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="• Страна показывает, через какой сервер будет работать подключение."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="• Строка режима трафика показывает, какие программы будут использовать VPN."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="• Карточка «Подписка» показывает дату окончания. Нажмите на неё, чтобы увидеть статус, страну и количество доступных устройств."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#5A0B1E3A" BorderBrush="#3672A4D4" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Режимы трафика"
                                                   Foreground="#B9D9FF"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Весь трафик через VPN"
                                                   Foreground="White" FontWeight="SemiBold" Margin="0,12,0,0" />
                                        <TextBlock Text="Через CosmoNet будут работать браузеры, мессенджеры, игры и остальные программы на компьютере. Это самый простой режим."
                                                   Foreground="#C7D8EC" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="Только выбранные приложения"
                                                   Foreground="White" FontWeight="SemiBold" Margin="0,12,0,0" />
                                        <TextBlock Text="Через VPN будут работать только отмеченные программы. Остальные приложения продолжат использовать обычное интернет-подключение."
                                                   Foreground="#C7D8EC" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="Как настроить: откройте меню → «Приложения», выберите режим, нажмите «Выбрать .exe», укажите нужную программу, поставьте галочку и нажмите «Сохранить». Если VPN уже включён, отключите и подключите его заново, чтобы применить изменения."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#5A0B1E3A" BorderBrush="#3672A4D4" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Подписка"
                                                   Foreground="#B9D9FF"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="После первой загрузки CosmoNet сохраняет ссылку подписки на этом компьютере и обновляет данные автоматически. На главном экране всегда видна дата окончания."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="Когда до окончания останется три дня или меньше, CosmoNet покажет предупреждение. После продления новая дата появится автоматически."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="Не передавайте другим людям ссылку подписки и код входа — они относятся только к вашему аккаунту."
                                                   Foreground="#F2C98D" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#5A0B1E3A" BorderBrush="#3672A4D4" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Вход через Telegram"
                                                   Foreground="#B9D9FF"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Значок Telegram в правом верхнем углу нужен для привязки аккаунта. Нажмите «Получить код», подтвердите этот код в боте CosmoNet и затем нажмите «Проверить»."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="Если бот не принимает код или подтверждение не появляется, продолжайте использовать личную ссылку подписки — для подключения VPN этого достаточно."
                                                   Foreground="#C7D8EC" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#5A0B1E3A" BorderBrush="#3672A4D4" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Сворачивание и работа в трее"
                                                   Foreground="#B9D9FF"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Кнопка «×» в правом верхнем углу не завершает CosmoNet — приложение скрывается в область уведомлений рядом с часами, а VPN продолжает работать."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="Чтобы вернуть окно, нажмите значок CosmoNet в трее правой кнопкой мыши и выберите «Открыть». Чтобы полностью закрыть приложение и отключить VPN, выберите в меню значка пункт «Выход»."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#5A0B1E3A" BorderBrush="#3672A4D4" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="Если VPN не подключается"
                                                   Foreground="#B9D9FF"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="1. Убедитесь, что интернет без VPN работает."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="2. Проверьте, что на главном экране написано «Сервер доступен», а подписка ещё действует."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="3. Закройте CosmoNet через пункт «Выход» в трее и запустите его снова от имени администратора."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="4. Если выбран режим «Только выбранные», проверьте, что нужная программа добавлена и отмечена галочкой."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="5. Откройте меню → «Логи», нажмите «Включить логи», повторите подключение и сохраните файл кнопкой «Сохранить .txt». Этот файл поможет поддержке быстро найти причину ошибки."
                                                   Foreground="#DCEAFF" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>
                <TabItem x:Name="LogsTab">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <WrapPanel>
                            <Button Content="Включить логи" Command="{Binding EnableLogsCommand}" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLogMonitoring}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Отключить логи" Command="{Binding DisableLogsCommand}" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLogMonitoring}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Очистить логи" Command="{Binding ClearLogsCommand}" Margin="0,0,8,0" />
                            <Button Content="Сохранить .txt" Command="{Binding SaveLogsCommand}" />
                        </WrapPanel>
                        <Border Grid.Row="2" Background="#C9102442" BorderBrush="#31567991" BorderThickness="1" CornerRadius="10" Padding="1">
                            <TextBox x:Name="VpnLogBox"
                                     Text="{Binding VpnLogText, Mode=OneWay}"
                                     TextChanged="OnVpnLogTextChanged"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#DCEAFF"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Padding="12" />
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem x:Name="FeedbackTab">
                    <Border Margin="0,10,0,0" Background="#CE102442" CornerRadius="14" Padding="22">
                        <StackPanel>
                            <TextBlock Text="Связаться с командой" Foreground="White" FontSize="21" FontWeight="SemiBold" />
                            <TextBlock Text="Опишите вопрос или предложение. Мы используем указанный контакт только для ответа на это обращение."
                                       Foreground="#AFC7E3" FontSize="12" Margin="0,6,0,20" TextWrapping="Wrap" />

                            <TextBlock Text="Как к вам обращаться" Foreground="#DCEAFF" FontWeight="SemiBold" FontSize="12" />
                            <TextBox Text="{Binding FeedbackName, UpdateSourceTrigger=PropertyChanged}" MaxLength="100" Margin="0,7,0,16" />

                            <TextBlock Text="Контакт для ответа" Foreground="#DCEAFF" FontWeight="SemiBold" FontSize="12" />
                            <TextBox Text="{Binding FeedbackContacts, UpdateSourceTrigger=PropertyChanged}" MaxLength="300" Margin="0,7,0,16" />

                            <TextBlock Text="Ваше обращение" Foreground="#DCEAFF" FontWeight="SemiBold" FontSize="12" />
                            <TextBox Text="{Binding FeedbackMessage, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="3000"
                                     Height="190"
                                     Margin="0,7,0,16"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled" />

                            <Button Content="Отправить обращение" Command="{Binding SubmitFeedbackCommand}" HorizontalAlignment="Left" Padding="18,8" />
                            <TextBlock Text="{Binding FeedbackStatus}" Foreground="#AFC7E3" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>

        <Border x:Name="MenuBackdrop" Grid.ZIndex="10" Margin="0,96,0,0" Background="#01000000" Visibility="Collapsed" Opacity="0" MouseLeftButtonDown="OnMenuBackdropMouseDown" />
        <Border x:Name="MenuPanel" Grid.ZIndex="11" Width="244" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="12,96,0,12" Padding="16" Background="#F30B1A33" BorderBrush="#4874A5D8" BorderThickness="1" CornerRadius="16" Visibility="Collapsed" Opacity="0" RenderTransformOrigin="0,0.5">
            <Border.RenderTransform><TranslateTransform X="-18" /></Border.RenderTransform>
            <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.35" Color="#000000" /></Border.Effect>
            <StackPanel><TextBlock Text="CosmoNet" Foreground="White" FontSize="19" FontWeight="SemiBold" Margin="4,6,0,20" /><ListBox Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource MenuItem}" SelectedIndex="{Binding SelectedIndex, ElementName=MainViews, Mode=TwoWay}" SelectionChanged="OnMenuSelectionChanged" PreviewMouseLeftButtonUp="OnMenuNavigationMouseUp"><ListBoxItem Content="Главная" /><ListBoxItem Content="Приложения" /><ListBoxItem Content="Инструкции" /><ListBoxItem Content="Логи" /><ListBoxItem Content="Обратная связь" /></ListBox></StackPanel>
        </Border>
        <Grid x:Name="SubscriptionDialogOverlay" Grid.ZIndex="40" Visibility="Collapsed">
            <Border x:Name="SubscriptionDialogBackdrop" Background="#B8081429" Opacity="0" MouseLeftButtonDown="OnSubscriptionDialogBackdropMouseDown" />
            <Border x:Name="SubscriptionDialogSurface" Width="430" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#F5102442" BorderBrush="#5A79A9E2" BorderThickness="1" CornerRadius="18" Padding="24" Opacity="0" RenderTransformOrigin="0.5,0.5" MouseLeftButtonDown="OnSubscriptionDialogMouseDown"><Border.RenderTransform><TransformGroup><ScaleTransform ScaleX="0.96" ScaleY="0.96" /><TranslateTransform Y="12" /></TransformGroup></Border.RenderTransform>
                <Border.Effect><DropShadowEffect BlurRadius="32" ShadowDepth="10" Opacity="0.45" Color="#000000" /></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Text="Подписка" Foreground="White" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Закрыть" Padding="12,6" Click="OnCloseSubscriptionDialogClick" />
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="185" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="30" /><RowDefinition Height="30" /><RowDefinition Height="30" /><RowDefinition Height="30" /></Grid.RowDefinitions>
                        <TextBlock Text="Статус:" Foreground="#AFC7E3" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><Ellipse Width="9" Height="9" Fill="{Binding SubscriptionModalStatusColor}" Margin="0,0,8,0" /><TextBlock Text="{Binding SubscriptionModalStatusText}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" /></StackPanel>
                        <TextBlock Grid.Row="1" Text="Действует до:" Foreground="#AFC7E3" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SubscriptionModalExpiresText}" Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Text="Страна:" Foreground="#AFC7E3" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ContentControl Width="20" Height="14" Content="{Binding CurrentCountryCode}" VerticalAlignment="Center" Margin="0,0,7,0">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ContentControl"><TextBlock Text="🌐" Foreground="White" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" /></ControlTemplate></Setter.Value></Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentCountryCode}" Value="NL">
                                                <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ContentControl"><Border BorderBrush="#6687A8C8" BorderThickness="0.5" CornerRadius="1" ClipToBounds="True"><Grid><Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions><Rectangle Grid.Row="0" Fill="#AE1C28" /><Rectangle Grid.Row="1" Fill="White" /><Rectangle Grid.Row="2" Fill="#21468B" /></Grid></Border></ControlTemplate></Setter.Value></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                            <TextBlock Text="{Binding CurrentCountryName}" Foreground="White" />
                        </StackPanel>
                        <TextBlock Grid.Row="3" Text="Устройств доступно:" Foreground="#AFC7E3" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SubscriptionModalDeviceLimitText}" Foreground="White" VerticalAlignment="Center" />

                    </Grid>
                    <Border Grid.Row="4" Background="#6113284A" BorderBrush="#2F6E9CCB" BorderThickness="1" CornerRadius="12" Padding="14" Visibility="{Binding ShowDevelopmentSubscriptionControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Режим разработки" Foreground="#B9D9FF" FontWeight="SemiBold" FontSize="12" />
                            <TextBox Text="{Binding SubscriptionUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,10,0,0" ToolTip="Ссылка подписки" />
                            <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Button Content="Загрузить" Command="{Binding RefreshCommand}" Grid.Column="0" /><Button Content="Обновить" Command="{Binding RefreshCommand}" Grid.Column="2" /></Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.ZIndex="30" Height="32" VerticalAlignment="Top" Background="#061A33" MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="38" />
                <ColumnDefinition Width="38" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="CosmoNet" Foreground="#DCEAFF" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0" />
            <Button Grid.Column="1" Style="{StaticResource TitleBarButton}" Content="−" ToolTip="Свернуть" Click="OnMinimizeClick" />
            <Button Grid.Column="2" Style="{StaticResource TitleBarButton}" Content="×" ToolTip="Скрыть в трей" Click="OnHideToTrayClick" />
        </Grid>
        <Grid x:Name="SubscriptionNotificationOverlay" Grid.ZIndex="60" Visibility="Collapsed">
            <Border x:Name="SubscriptionNotificationBackdrop" Background="#C8081429" Opacity="0" />
            <Border x:Name="SubscriptionNotificationSurface" Width="410" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#F5102442" BorderBrush="#6F77B7FF" BorderThickness="1" CornerRadius="16" Padding="22" Opacity="0" RenderTransformOrigin="0.5,0.5"><Border.RenderTransform><TransformGroup><ScaleTransform ScaleX="0.94" ScaleY="0.94" /><TranslateTransform Y="10" /></TransformGroup></Border.RenderTransform>
                <Border.Effect><DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.45" Color="#000000" /></Border.Effect>
                <StackPanel>
                    <TextBlock Text="CosmoNet" Foreground="#B9D9FF" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding SubscriptionNotificationText, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="White" FontSize="15" TextWrapping="Wrap" TextAlignment="Center" Margin="0,14,0,20" />
                    <Button Content="ОК" Width="104" HorizontalAlignment="Center" Click="OnCloseSubscriptionNotificationClick" />
                </StackPanel>
            </Border>
        </Grid>        <Border x:Name="SaveToast" Grid.ZIndex="20" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28" Padding="16,10" Background="#E71C3552" BorderBrush="#608FC9FF" BorderThickness="1" CornerRadius="10" Opacity="0" Visibility="Collapsed" IsHitTestVisible="False">
            <TextBlock Text="Настройки сохранены" Foreground="White" FontWeight="SemiBold" />
        </Border>
    </Grid>
</Window>
